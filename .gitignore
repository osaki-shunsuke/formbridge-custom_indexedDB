npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OSのシステムファイル
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# エディタやIDEの設定ファイル
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
